{
  "name": "gold-prices",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/node/extract-baseline.js && node scripts/node/normalize-shops.js && vite build",
    "extract-baseline": "node scripts/node/extract-baseline.js",
    "normalize-shops": "node scripts/node/normalize-shops.js",
    "release:package": "node scripts/node/package-release.js",
    "preview": "vite preview",
    "start": "node server.js",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "test:watch": "node --test --test-concurrency=1 --watch tests/*.test.js",
    "test:coverage": "node --test --test-concurrency=1 --experimental-test-coverage tests/*.test.js",
    "test:playwright": "npx playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "style": "stylelint '**/*.css'",
    "style:fix": "stylelint '**/*.css' --fix",
    "quality": "npm run lint && npm run format:check && npm run style",
    "seo-audit": "node scripts/node/seo-audit.js",
    "a11y": "pa11y-ci --config .pa11yci.js",
    "check-links": "node scripts/node/check-links.js",
    "audit-pages": "node scripts/node/audit-pages.js",
    "generate-sitemap": "node scripts/node/generate-sitemap.js",
    "preflight": "npm run audit-pages && npm run check-links",
    "validate": "node scripts/node/validate-build.js",
    "security": "npm audit && npm outdated",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "pa11y-ci": "^6.0.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1",
    "terser": "^5.46.1",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lowdb": "^3.0.0",
    "morgan": "^1.10.1",
    "uuid": "^13.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,html}": [
      "prettier --write"
    ]
  }
}
