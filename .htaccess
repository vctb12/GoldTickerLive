# ═══════════════════════════════════════════════════════════════
# Route Reorganization Redirects (cities/markets moved under countries)
# ═══════════════════════════════════════════════════════════════

<IfModule mod_rewrite.c>
RewriteEngine On

# Redirect legacy GitHub Pages base-path URLs to root equivalents
RewriteRule ^Gold-Prices/?(.*)$ /$1 [R=301,L]

# 2026-07-04 radical page reduction: the countries/, content/, ar/, chart/,
# gold-price/, methodology/ trees and several root pages were removed. Mirror
# the tree-level sweeps in _redirects (Netlify/Cloudflare) so an Apache host
# retargets every removed URL to the closest surviving surface instead of 404.

# Legacy city/market paths (previously rewritten under the countries/ tree).
RewriteRule ^cities/ /compare.html [R=301,L]
RewriteRule ^markets/ /compare.html [R=301,L]

# Removed page trees → closest surviving surface.
RewriteRule ^countries(/.*)?$ /compare.html [R=301,L]
RewriteRule ^content(/.*)?$ /learn.html [R=301,L]
RewriteRule ^ar(/.*)?$ /?lang=ar [R=301,L]
RewriteRule ^chart(/.*)?$ /tracker.html [R=301,L]
RewriteRule ^gold-price(/.*)?$ /tracker.html [R=301,L]
RewriteRule ^methodology/ /methodology.html [R=301,L]

# Removed root pages → home / knowledge hub.
RewriteRule ^account\.html$ / [R=301,L]
RewriteRule ^dashboard\.html$ / [R=301,L]
RewriteRule ^pricing\.html$ / [R=301,L]
RewriteRule ^developer\.html$ / [R=301,L]
RewriteRule ^design-lab\.html$ / [R=301,L]
RewriteRule ^insights\.html$ /learn.html#insights [R=301,L]
RewriteRule ^invest\.html$ /learn.html#invest [R=301,L]

</IfModule>

# ═══════════════════════════════════════════════════════════════
# Security Headers
# ═══════════════════════════════════════════════════════════════
# ⚠️  HOST CAVEAT: these Header directives only take effect on an Apache host
# with mod_headers. The default production deploy (.github/workflows/deploy.yml)
# copies this file into dist/ but publishes to GitHub Pages, which serves it as
# a static file and does NOT process .htaccess — so NONE of the headers below
# are emitted on the public site. To ship them, front the site with Apache /
# Cloudflare / Netlify, or set equivalent Cloudflare Transform Rules. The
# parity note on HSTS below refers to value parity, not to where it is applied.

<IfModule mod_headers.c>
  # Prevent MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Block clickjacking
  Header always set X-Frame-Options "DENY"

  # Enforce HTTPS (1 year, includeSubDomains, preload-eligible).
  # Matches Helmet hsts() in server.js for the dynamic admin/API host.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Control referrer information
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Restrict browser features the site does not use. Kept in sync with
  # Helmet's default Permissions-Policy footprint and the _headers file.
  Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"

  # Prevent cross-origin information leakage
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
</IfModule>

# ═══════════════════════════════════════════════════════════════
# Service Worker & Static Assets Caching
# ═══════════════════════════════════════════════════════════════

# Cache busting for versioned assets
<Files "*.v[0-9]*.js">
  Header set Cache-Control "max-age=31536000, public, immutable"
</Files>

<Files "*.v[0-9]*.css">
  Header set Cache-Control "max-age=31536000, public, immutable"
</Files>

# Service worker and index should not be cached
<Files "sw.js">
  Header set Cache-Control "max-age=0, public, must-revalidate"
</Files>

<Files "index.html">
  Header set Cache-Control "max-age=3600, public"
</Files>

# Static pages (except index) are somewhat cacheable
<FilesMatch "\.(html)$">
  Header set Cache-Control "max-age=86400, public"
</FilesMatch>
