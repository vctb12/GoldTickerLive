# ═══════════════════════════════════════════════════════════════
# Route Reorganization Redirects (cities/markets moved under countries)
# ═══════════════════════════════════════════════════════════════

<IfModule mod_rewrite.c>
RewriteEngine On

# Redirect legacy GitHub Pages base-path URLs to root equivalents
RewriteRule ^Gold-Prices/?(.*)$ /$1 [R=301,L]

# Redirect old city paths to new structure
RewriteRule ^cities/dubai\.html$ countries/uae/cities/dubai.html [R=301,L]
RewriteRule ^cities/abu-dhabi\.html$ countries/uae/cities/abu-dhabi.html [R=301,L]
RewriteRule ^cities/cairo\.html$ countries/egypt/cities/cairo.html [R=301,L]
RewriteRule ^cities/doha\.html$ countries/qatar/cities/doha.html [R=301,L]
RewriteRule ^cities/riyadh\.html$ countries/saudi-arabia/cities/riyadh.html [R=301,L]

# Redirect old market paths to new structure
RewriteRule ^markets/dubai-gold-souk\.html$ countries/uae/markets/dubai-gold-souk.html [R=301,L]
RewriteRule ^markets/khan-el-khalili-cairo\.html$ countries/egypt/markets/khan-el-khalili-cairo.html [R=301,L]

# Country pages: flat /countries/<slug>.html → /countries/<slug>/ (directory form).
# Mirrors the same 21-slug set already in _redirects (Netlify/Cloudflare). Real pages
# live at countries/<slug>/index.html; the flat .html form 404s without these rules.
RewriteRule ^countries/uae\.html$ /countries/uae/ [R=301,L]
RewriteRule ^countries/saudi-arabia\.html$ /countries/saudi-arabia/ [R=301,L]
RewriteRule ^countries/bahrain\.html$ /countries/bahrain/ [R=301,L]
RewriteRule ^countries/kuwait\.html$ /countries/kuwait/ [R=301,L]
RewriteRule ^countries/jordan\.html$ /countries/jordan/ [R=301,L]
RewriteRule ^countries/qatar\.html$ /countries/qatar/ [R=301,L]
RewriteRule ^countries/oman\.html$ /countries/oman/ [R=301,L]
RewriteRule ^countries/egypt\.html$ /countries/egypt/ [R=301,L]
RewriteRule ^countries/morocco\.html$ /countries/morocco/ [R=301,L]
RewriteRule ^countries/india\.html$ /countries/india/ [R=301,L]
RewriteRule ^countries/pakistan\.html$ /countries/pakistan/ [R=301,L]
RewriteRule ^countries/turkey\.html$ /countries/turkey/ [R=301,L]
RewriteRule ^countries/iraq\.html$ /countries/iraq/ [R=301,L]
RewriteRule ^countries/syria\.html$ /countries/syria/ [R=301,L]
RewriteRule ^countries/lebanon\.html$ /countries/lebanon/ [R=301,L]
RewriteRule ^countries/palestine\.html$ /countries/palestine/ [R=301,L]
RewriteRule ^countries/yemen\.html$ /countries/yemen/ [R=301,L]
RewriteRule ^countries/sudan\.html$ /countries/sudan/ [R=301,L]
RewriteRule ^countries/libya\.html$ /countries/libya/ [R=301,L]
RewriteRule ^countries/tunisia\.html$ /countries/tunisia/ [R=301,L]
RewriteRule ^countries/algeria\.html$ /countries/algeria/ [R=301,L]

</IfModule>

# ═══════════════════════════════════════════════════════════════
# Security Headers
# ═══════════════════════════════════════════════════════════════
# ⚠️  HOST CAVEAT: these Header directives only take effect on an Apache host
# with mod_headers. The default production deploy (.github/workflows/deploy.yml)
# copies this file into dist/ but publishes to GitHub Pages, which serves it as
# a static file and does NOT process .htaccess — so NONE of the headers below
# are emitted on the public site. To ship them, front the site with Apache /
# Cloudflare / Netlify, or set equivalent Cloudflare Transform Rules. The
# parity note on HSTS below refers to value parity, not to where it is applied.

<IfModule mod_headers.c>
  # Prevent MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Block clickjacking
  Header always set X-Frame-Options "DENY"

  # Enforce HTTPS (1 year, includeSubDomains, preload-eligible).
  # Matches Helmet hsts() in server.js for the dynamic admin/API host.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Control referrer information
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Restrict browser features the site does not use. Kept in sync with
  # Helmet's default Permissions-Policy footprint and the _headers file.
  Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"

  # Prevent cross-origin information leakage
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
</IfModule>

# ═══════════════════════════════════════════════════════════════
# Service Worker & Static Assets Caching
# ═══════════════════════════════════════════════════════════════

# Cache busting for versioned assets
<Files "*.v[0-9]*.js">
  Header set Cache-Control "max-age=31536000, public, immutable"
</Files>

<Files "*.v[0-9]*.css">
  Header set Cache-Control "max-age=31536000, public, immutable"
</Files>

# Service worker and index should not be cached
<Files "sw.js">
  Header set Cache-Control "max-age=0, public, must-revalidate"
</Files>

<Files "index.html">
  Header set Cache-Control "max-age=3600, public"
</Files>

# Static pages (except index) are somewhat cacheable
<FilesMatch "\.(html)$">
  Header set Cache-Control "max-age=86400, public"
</FilesMatch>
