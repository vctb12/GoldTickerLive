{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "//": "Permission policy for autonomous / overnight Claude Code sessions on Gold Ticker Live. DENY rules take precedence over ALLOW. This is one of two required safety layers (the other is scripts/agent-night-run.sh). Do not weaken the deny list. See AGENTS.md 'Overnight autonomous agent' and docs/AGENT_MASTER_TRACKER.md guardrails.",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./styles/**)",
      "Edit(./tests/**)",
      "Edit(./docs/**)",
      "Edit(./scripts/**)",
      "Edit(./public/**)",
      "Edit(./*.html)",
      "Edit(./*.md)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npm run lint)",
      "Bash(npm run lint:css)",
      "Bash(npm test)",
      "Bash(npm run build)",
      "Bash(npm run validate)",
      "Bash(npm run format:check)",
      "Bash(npm run quality)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git push -u origin cowork/:*)",
      "Bash(git push origin cowork/:*)",
      "Bash(git push -u origin claude/:*)",
      "Bash(git push origin claude/:*)",
      "Bash(git push -u origin agent/:*)",
      "Bash(git push origin agent/:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./**/.env)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/id_rsa*)",
      "Read(./**/secrets*.json)",
      "Read(./**/credentials*.json)",
      "Edit(./.env*)",
      "Write(./.env*)",
      "Edit(./**/*.pem)",
      "Edit(./**/*.key)",
      "Edit(./**/secrets*.json)",
      "Edit(./**/credentials*.json)",
      "Write(./**/secrets*.json)",
      "Edit(./.github/workflows/gold-price-fetch.yml)",
      "Write(./.github/workflows/gold-price-fetch.yml)",
      "Edit(./.github/workflows/post_gold.yml)",
      "Write(./.github/workflows/post_gold.yml)",
      "Edit(./sw.js)",
      "Write(./sw.js)",
      "Edit(./src/config/constants.js)",
      "Write(./src/config/constants.js)",
      "Bash(git push:*main:*)",
      "Bash(git push origin main:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh workflow run deploy:*)",
      "Bash(npm run deploy:*)",
      "Bash(npm run pre-deploy:*)",
      "Bash(vercel:*)",
      "Bash(netlify:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
