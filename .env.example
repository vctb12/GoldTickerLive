# ------------------------------------------------------------------
# Sample environment variables for Gold Ticker Live data + automation.
# Copy to .env (gitignored) for local development.
# Production values live in GitHub Secrets.
#
# DO NOT COMMIT REAL SECRETS TO THIS REPO.
# ------------------------------------------------------------------

# ── Provider adapter selection ────────────────────────────────────
# Comma-separated provider names tried in order. Values must come
# from the registry in scripts/python/gold_providers/registry.py.
# Known names: metal_sentinel, finnhub_oanda, fmp_gcusd, goldapi_io,
#              twelvedata_xauusd, goldpricez, gold_api_com.
GOLD_PROVIDER_ORDER=metal_sentinel,finnhub_oanda,fmp_gcusd,goldapi_io,twelvedata_xauusd,goldpricez

# ── Common pricing / freshness knobs ──────────────────────────────
AED_PEG=3.6725
MAX_GOLD_FRESHNESS_SECONDS=900
MIN_VALID_XAU_USD=500
MAX_VALID_XAU_USD=10000
HTTP_TIMEOUT_SECONDS=10
HTTP_RETRIES=1
SOFT_FAIL_ON_NO_FRESH_PRICE=true
ALLOW_STALE_PRICE=false

# ── X / Twitter duplicate-prevention knobs ────────────────────────
SKIP_DUPLICATE_TWEETS=true
ALLOW_STALE_TWEET=false
DRY_RUN_TWEET=false
MIN_TWEET_MOVE_USD=1.00
MIN_TWEET_MOVE_PCT=0.03
FORCE_SUMMARY_AFTER_MINUTES=60

# ── Bakeoff knobs ─────────────────────────────────────────────────
# Set to true to capture full raw response bodies (very verbose; never
# enable in production where API keys could be reflected back). Hashes
# are recorded by default so freezing/duplicates can still be detected.
BAKEOFF_LOG_RAW=false

# ── Provider: Metal Sentinel ──────────────────────────────────────
METAL_SENTINEL_ENABLED=false
METAL_SENTINEL_API_KEY=
METAL_SENTINEL_API_HOST=
METAL_SENTINEL_AUTH_HEADER=x-api-key
METAL_SENTINEL_ENDPOINT=

# ── Provider: Finnhub (OANDA XAU/USD) ─────────────────────────────
FINNHUB_ENABLED=false
FINNHUB_API_KEY=
FINNHUB_SYMBOL=OANDA:XAU_USD

# ── Provider: Financial Modeling Prep (GCUSD) ─────────────────────
FMP_ENABLED=false
FMP_API_KEY=
FMP_SYMBOL=GCUSD

# ── Provider: GoldAPI.io ──────────────────────────────────────────
# NOT to be confused with gold-api.com. Free tier quota historically
# very low; treat as candidate only until bakeoff confirms.
GOLDAPI_IO_ENABLED=false
GOLDAPI_IO_KEY=

# ── Provider: Twelve Data ─────────────────────────────────────────
TWELVEDATA_ENABLED=false
TWELVEDATA_API_KEY=
TWELVEDATA_SYMBOL=XAU/USD

# ── Provider: GoldPriceZ (legacy) ─────────────────────────────────
# Default-enabled because this is the existing production source. Set
# to false once the bakeoff produces a winner.
GOLDPRICEZ_ENABLED=true
GOLDPRICEZ_API_KEY=

# ── Provider: gold-api.com (legacy reference) ─────────────────────
# Disabled — historically rate-limited in this project. Re-enable
# only for bakeoff measurement.
GOLD_API_COM_ENABLED=false
GOLD_API_COM_KEY=

# ── X / Twitter API credentials (production: GitHub Secrets) ──────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
